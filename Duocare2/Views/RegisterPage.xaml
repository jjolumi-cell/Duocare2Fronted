<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Duocare2.Views.RegisterPage"
             Title="Crear cuenta">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#A8C5FF" Offset="0.0" />
            <GradientStop Color="#F0F6FF" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="30">

            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                <Label Text="Crear cuenta"
                       FontSize="34"
                       TextColor="#2A2A2A"
                       FontAttributes="Bold"/>
                <Label Text="Completa tus datos para continuar"
                       FontSize="16"
                       TextColor="#6A6A6A"/>
            </VerticalStackLayout>

            <Frame BackgroundColor="White"
                   CornerRadius="25"
                   Padding="25"
                   HasShadow="True"
                   BorderColor="#DDE6F2">

                <VerticalStackLayout Spacing="25">

                    <!-- Nombre -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Nombre completo"
                               FontSize="15"
                               TextColor="#3A3A3A"
                               FontAttributes="Bold"/>
                        <Frame BackgroundColor="#F7F9FC"
                               BorderColor="#C9D6E8"
                               CornerRadius="12"
                               Padding="12">
                            <Entry Placeholder="Introduce tu nombre"
                                   Text="{Binding Nombre}"
                                   TextColor="#1A1A1A"
                                   PlaceholderColor="#9AA4B1"
                                   BackgroundColor="Transparent"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Correo -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Correo electrónico"
                               FontSize="15"
                               TextColor="#3A3A3A"
                               FontAttributes="Bold"/>
                        <Frame BackgroundColor="#F7F9FC"
                               BorderColor="#C9D6E8"
                               CornerRadius="12"
                               Padding="12">
                            <Entry Placeholder="Introduce tu correo"
                                   Text="{Binding Email}"
                                   Keyboard="Email"
                                   TextColor="#1A1A1A"
                                   PlaceholderColor="#9AA4B1"
                                   BackgroundColor="Transparent"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Contraseña -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Contraseña"
                               FontSize="15"
                               TextColor="#3A3A3A"
                               FontAttributes="Bold"/>
                        <Frame BackgroundColor="#F7F9FC"
                               BorderColor="#C9D6E8"
                               CornerRadius="12"
                               Padding="12">
                            <Entry Placeholder="Introduce tu contraseña"
                                   Text="{Binding Password}"
                                   IsPassword="True"
                                   TextColor="#1A1A1A"
                                   PlaceholderColor="#9AA4B1"
                                   BackgroundColor="Transparent"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Repetir contraseña -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Repite la contraseña"
                               FontSize="15"
                               TextColor="#3A3A3A"
                               FontAttributes="Bold"/>

                        <Frame BackgroundColor="#F7F9FC"
                               CornerRadius="12"
                               Padding="12"
                               BorderColor="{Binding ConfirmPasswordBorderColor}">
                            <Entry Placeholder="Repite tu contraseña"
                                   Text="{Binding ConfirmPassword}"
                                   IsPassword="True"
                                   TextColor="#1A1A1A"
                                   PlaceholderColor="#9AA4B1"
                                   BackgroundColor="Transparent"/>
                        </Frame>

                        <Label Text="{Binding ConfirmPasswordMessage}"
                               FontSize="13"
                               TextColor="{Binding ConfirmPasswordMessageColor}"
                               HorizontalOptions="Start"/>
                    </VerticalStackLayout>

                    <Button Text="Registrarse"
                            Command="{Binding RegisterCommand}"
                            BackgroundColor="#5A8CFF"
                            TextColor="White"
                            CornerRadius="15"
                            HeightRequest="55"
                            FontSize="18"
                            FontAttributes="Bold"/>
                </VerticalStackLayout>

            </Frame>

            <Label Text="¿Ya tienes cuenta? Inicia sesión desde el menú."
                    FontSize="14"
                    HorizontalOptions="Center"
                    TextColor="#4A6CFF">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding IrALoginCommand}" />
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
