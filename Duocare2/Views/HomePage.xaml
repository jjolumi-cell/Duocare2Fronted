<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Duocare2.Views.HomePage"
             Title="Panel de custodia">

    <Grid>

        <!-- 🖼️ IMAGEN DE FONDO CORRECTA EN MAUI -->
        <Image Source="fondo.jpg"
               Aspect="AspectFill"
               Opacity="1"
               IsEnabled="False" />

        <!-- CONTENIDO ENCIMA -->
        <VerticalStackLayout Padding="25" Spacing="35">

            <!-- TÍTULO -->
            <Label Text="Panel de custodia"
                   FontSize="34"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="White"
                   Margin="0,10,0,10"/>

            <!-- TARJETAS -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="25">

                <!-- TARJETA NIÑO -->
                <Frame Grid.Column="0"
                       CornerRadius="28"
                       Padding="0"
                       HasShadow="True"
                       HeightRequest="420">

                    <Grid>

                        <Image Source="ninos.jpg"
                               Aspect="AspectFill"
                               Opacity="0.85"/>

                        <BoxView Color="#80000000"/>

                        <VerticalStackLayout Spacing="18"
                                             Padding="25"
                                             VerticalOptions="Center"
                                             HorizontalOptions="Center">

                            <Label Text="👦"
                                   FontSize="60"
                                   HorizontalOptions="Center"/>

                            <Label Text="Niño"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"/>

                            <Label Text="{Binding NombreNiño, TargetNullValue='No registrado'}"
                                   FontSize="18"
                                   TextColor="White"
                                   HorizontalOptions="Center"/>

                            <Button Text="Calendario niño"
                                    BackgroundColor="#4A90E2"
                                    TextColor="White"
                                    CornerRadius="20"
                                    HeightRequest="52"
                                    WidthRequest="210"
                                    FontAttributes="Bold"
                                    HorizontalOptions="Center"
                                    Clicked="AbrirCalendarioNiño"/>

                        </VerticalStackLayout>

                    </Grid>
                </Frame>

                <!-- TARJETA MASCOTA -->
                <Frame Grid.Column="1"
                       CornerRadius="28"
                       Padding="0"
                       HasShadow="True"
                       HeightRequest="420">

                    <Grid>

                        <Image Source="animales.jpg"
                               Aspect="AspectFill"
                               Opacity="0.85"/>

                        <BoxView Color="#80000000"/>

                        <VerticalStackLayout Spacing="18"
                                             Padding="25"
                                             VerticalOptions="Center"
                                             HorizontalOptions="Center">

                            <Label Text="🐶"
                                   FontSize="60"
                                   HorizontalOptions="Center"/>

                            <Label Text="Mascota"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"/>

                            <Label Text="{Binding NombreMascota, TargetNullValue='No registrada'}"
                                   FontSize="18"
                                   TextColor="White"
                                   HorizontalOptions="Center"/>

                            <Button Text="Calendario mascota"
                                    BackgroundColor="#F5A623"
                                    TextColor="White"
                                    CornerRadius="20"
                                    HeightRequest="52"
                                    WidthRequest="210"
                                    FontAttributes="Bold"
                                    HorizontalOptions="Center"
                                    Clicked="AbrirCalendarioMascota"/>

                        </VerticalStackLayout>

                    </Grid>
                </Frame>

            </Grid>

        </VerticalStackLayout>

    </Grid>

</ContentPage>
