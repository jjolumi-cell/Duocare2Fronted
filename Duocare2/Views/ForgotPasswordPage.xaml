<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Duocare2.Views.ForgotPasswordPage"
             Title="Recuperar contraseña">

    <!-- FONDO BONITO (igual que Register y Login) -->
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#A8C5FF" Offset="0.0" />
            <GradientStop Color="#F0F6FF" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="30">

            <!-- Título -->
            <Label Text="Recuperar contraseña"
                   FontSize="30"
                   HorizontalOptions="Center"
                   TextColor="#2A2A2A"
                   FontAttributes="Bold"/>

            <Label Text="Introduce tu correo y te enviaremos instrucciones"
                   FontSize="15"
                   TextColor="#6A6A6A"
                   HorizontalOptions="Center"/>

            <!-- Tarjeta -->
            <Frame BackgroundColor="White"
                   CornerRadius="25"
                   Padding="25"
                   HasShadow="True"
                   BorderColor="#DDE6F2">

                <VerticalStackLayout Spacing="20">

                    <!-- Correo -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Correo electrónico"
                               FontSize="15"
                               TextColor="#3A3A3A"
                               FontAttributes="Bold"/>

                        <Frame BackgroundColor="#F7F9FC"
                               BorderColor="#C9D6E8"
                               CornerRadius="12"
                               Padding="12">

                            <Entry Placeholder="Introduce tu correo"
                                   Text="{Binding Email}"
                                   Keyboard="Email"
                                   TextColor="#1A1A1A"
                                   PlaceholderColor="#9AA4B1"
                                   BackgroundColor="Transparent"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Botón enviar -->
                    <Button Text="Enviar instrucciones"
                            Command="{Binding SendCommand}"
                            BackgroundColor="#5A8CFF"
                            TextColor="White"
                            CornerRadius="15"
                            HeightRequest="55"
                            FontSize="18"
                            FontAttributes="Bold"/>

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
