<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Duocare2.Views.FichaPage"
             BackgroundColor="#F2F2F7"
             Title="Ficha">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="25">

            <!-- TÍTULO -->
            <Label Text="Ficha del menor / mascota"
                   FontSize="30"
                   HorizontalOptions="Center"
                   TextColor="#1A1A1A"
                   FontAttributes="Bold"/>

            <!-- PESTAÑAS -->
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">

                <Frame Padding="12,6"
                       CornerRadius="10"
                       BorderColor="{Binding TabNiñoBorder}"
                       BackgroundColor="{Binding TabNiñoBackground}">
                    <Label Text="Niño/a"
                           TextColor="{Binding TabNiñoText}"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CambiarTabCommand}" CommandParameter="Niño" />
                        </Label.GestureRecognizers>
                    </Label>
                </Frame>

                <Frame Padding="12,6"
                       CornerRadius="10"
                       BorderColor="{Binding TabMascotaBorder}"
                       BackgroundColor="{Binding TabMascotaBackground}">
                    <Label Text="Mascota"
                           TextColor="{Binding TabMascotaText}"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CambiarTabCommand}" CommandParameter="Mascota" />
                        </Label.GestureRecognizers>
                    </Label>
                </Frame>

                <Frame Padding="12,6"
                       CornerRadius="10"
                       BorderColor="{Binding TabAmbosBorder}"
                       BackgroundColor="{Binding TabAmbosBackground}">
                    <Label Text="Ambos"
                           TextColor="{Binding TabAmbosText}"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CambiarTabCommand}" CommandParameter="Ambos" />
                        </Label.GestureRecognizers>
                    </Label>
                </Frame>

            </HorizontalStackLayout>


            <!-- ========================= -->
            <!-- FICHA NIÑO (DINÁMICA) -->
            <!-- ========================= -->
            <Frame BackgroundColor="White"
                   CornerRadius="25"
                   Padding="25"
                   HasShadow="True"
                   BorderColor="#DADADA"
                   IsVisible="{Binding MostrarNiño}">

                <VerticalStackLayout Spacing="22">

                    <!-- Título + botón añadir -->
                    <HorizontalStackLayout HorizontalOptions="Fill" VerticalOptions="Center">
                        <Label Text="Ficha del niño/a"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A"
                               HorizontalOptions="StartAndExpand"/>

                        <Frame BackgroundColor="#5A4FCF"
                               Padding="6"
                               CornerRadius="20">
                            <Label Text="+"
                                   FontSize="20"
                                   TextColor="White">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding AñadirNiñoCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Frame>
                    </HorizontalStackLayout>

                    <!-- LISTA DE NIÑOS -->
                    <CollectionView ItemsSource="{Binding ListaNiños}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Spacing="15">

                                    <!-- Nombre -->
                                    <VerticalStackLayout Spacing="5">
                                        <Label Text="Nombre del niño/a"
                                               FontSize="17"
                                               TextColor="#1A1A1A"
                                               FontAttributes="Bold"/>

                                        <Frame BackgroundColor="#FFFFFF"
                                               BorderColor="#C7C7CC"
                                               CornerRadius="12"
                                               Padding="10">
                                            <Entry Placeholder="Introduce el nombre"
                                                   Text="{Binding Nombre}"
                                                   TextColor="Black"
                                                   PlaceholderColor="#8E8E93"
                                                   BackgroundColor="Transparent"/>
                                        </Frame>
                                    </VerticalStackLayout>

                                    <!-- Fecha nacimiento -->
                                    <VerticalStackLayout Spacing="5">
                                        <Label Text="Fecha de nacimiento"
                                               FontSize="17"
                                               TextColor="#1A1A1A"
                                               FontAttributes="Bold"/>

                                        <Frame BackgroundColor="#FFFFFF"
                                               BorderColor="#C7C7CC"
                                               CornerRadius="12"
                                               Padding="10">
                                            <DatePicker Date="{Binding FechaNacimiento}"
                                                        TextColor="Black"
                                                        BackgroundColor="Transparent"/>
                                        </Frame>
                                    </VerticalStackLayout>

                                    <!-- Notas -->
                                    <VerticalStackLayout Spacing="5">
                                        <Label Text="Notas"
                                               FontSize="17"
                                               TextColor="#1A1A1A"
                                               FontAttributes="Bold"/>

                                        <Frame BackgroundColor="#FFFFFF"
                                               BorderColor="#C7C7CC"
                                               CornerRadius="12"
                                               Padding="10">
                                            <Editor Placeholder="Escribe aquí cualquier información importante"
                                                    Text="{Binding Notas}"
                                                    TextColor="Black"
                                                    PlaceholderColor="#8E8E93"
                                                    AutoSize="TextChanges"
                                                    BackgroundColor="Transparent"/>
                                        </Frame>
                                    </VerticalStackLayout>

                                    <BoxView HeightRequest="1" Color="#E0E0E0"/>

                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>


            <!-- ========================= -->
            <!-- FICHA MASCOTA -->
            <!-- ========================= -->
            <Frame BackgroundColor="White"
                   CornerRadius="25"
                   Padding="25"
                   HasShadow="True"
                   BorderColor="#DADADA"
                   IsVisible="{Binding MostrarMascota}">

                <VerticalStackLayout Spacing="22">

                    <Label Text="Ficha de la mascota"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#1A1A1A"/>

                    <!-- Nombre mascota -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Nombre de la mascota"
                               FontSize="17"
                               TextColor="#1A1A1A"
                               FontAttributes="Bold"/>

                        <Frame BackgroundColor="#FFFFFF"
                               BorderColor="#C7C7CC"
                               CornerRadius="12"
                               Padding="10">
                            <Entry Placeholder="Introduce el nombre"
                                   Text="{Binding NombreMascota}"
                                   TextColor="Black"
                                   PlaceholderColor="#8E8E93"
                                   BackgroundColor="Transparent"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Tipo mascota -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Tipo de mascota"
                               FontSize="17"
                               TextColor="#1A1A1A"
                               FontAttributes="Bold"/>

                        <Frame BackgroundColor="#FFFFFF"
                               BorderColor="#C7C7CC"
                               CornerRadius="12"
                               Padding="10">
                            <Picker Title="Selecciona tipo"
                                    ItemsSource="{Binding TiposMascota}"
                                    SelectedItem="{Binding TipoMascota, Mode=TwoWay}"
                                    TextColor="Black"
                                    BackgroundColor="Transparent"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Campo 'Otro' -->
                    <VerticalStackLayout Spacing="5"
                                         IsVisible="{Binding MostrarOtro}">
                        <Label Text="Especifica la mascota"
                               FontSize="17"
                               TextColor="#1A1A1A"
                               FontAttributes="Bold"/>

                        <Frame BackgroundColor="#FFFFFF"
                               BorderColor="#C7C7CC"
                               CornerRadius="12"
                               Padding="10">
                            <Entry Placeholder="Introduce el tipo de mascota"
                                   Text="{Binding MascotaOtro}"
                                   TextColor="Black"
                                   PlaceholderColor="#8E8E93"
                                   BackgroundColor="Transparent"/>
                        </Frame>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>


            <!-- ========================= -->
            <!-- FICHA AMBOS -->
            <!-- ========================= -->
            <Frame BackgroundColor="White"
                   CornerRadius="25"
                   Padding="25"
                   HasShadow="True"
                   BorderColor="#DADADA"
                   IsVisible="{Binding MostrarAmbos}">

                <VerticalStackLayout Spacing="25">

                    <Label Text="Ficha del niño/a"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#1A1A1A"/>

                    <Entry Placeholder="Nombre del niño/a"
                           Text="{Binding NombreNiño}"
                           TextColor="Black"/>

                    <DatePicker Date="{Binding FechaNacimientoNiño}"
                                TextColor="Black"/>

                    <Editor Placeholder="Notas del niño/a"
                            Text="{Binding NotasNiño}"
                            AutoSize="TextChanges"
                            TextColor="Black"/>

                    <Label Text="Ficha de la mascota"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#1A1A1A"/>

                    <Entry Placeholder="Nombre de la mascota"
                           Text="{Binding NombreMascota}"
                           TextColor="Black"/>

                    <Picker Title="Tipo de mascota"
                            ItemsSource="{Binding TiposMascota}"
                            SelectedItem="{Binding TipoMascota}"
                            TextColor="Black"/>

                    <Entry Placeholder="Especifica la mascota"
                           Text="{Binding MascotaOtro}"
                           TextColor="Black"
                           IsVisible="{Binding MostrarOtro}"/>

                    <Editor Placeholder="Notas de la mascota"
                            Text="{Binding NotasMascota}"
                            AutoSize="TextChanges"
                            TextColor="Black"/>

                </VerticalStackLayout>
            </Frame>


            <!-- BOTÓN GUARDAR -->
            <Button Text="Guardar"
                    Command="{Binding GuardarCommand}"
                    BackgroundColor="#5A4FCF"
                    TextColor="White"
                    CornerRadius="15"
                    HeightRequest="50"
                    FontSize="18"
                    FontAttributes="Bold"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
