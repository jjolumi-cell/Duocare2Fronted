<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Duocare2.Views.LoginPage"
             Title="Iniciar sesión">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#A8C5FF" Offset="0.0" />
            <GradientStop Color="#F0F6FF" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="30">

            <!-- Título -->
            <Label Text="Duocare"
                   FontSize="36"
                   HorizontalOptions="Center"
                   TextColor="#2A2A2A"
                   FontAttributes="Bold"/>

            <!-- Tarjeta -->
            <Frame BackgroundColor="White"
                   CornerRadius="25"
                   Padding="25"
                   HasShadow="True"
                   BorderColor="#DDE6F2">

                <VerticalStackLayout Spacing="20">

                    <!-- Correo -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Correo electrónico"
                               FontSize="15"
                               TextColor="#3A3A3A"
                               FontAttributes="Bold"/>

                        <Frame BackgroundColor="#F7F9FC"
                               BorderColor="#C9D6E8"
                               CornerRadius="12"
                               Padding="12">

                            <Entry Placeholder="Introduce tu correo"
                                   Text="{Binding Email}"
                                   Keyboard="Email"
                                   TextColor="#1A1A1A"
                                   PlaceholderColor="#9AA4B1"
                                   BackgroundColor="Transparent"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Contraseña -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Contraseña"
                               FontSize="15"
                               TextColor="#3A3A3A"
                               FontAttributes="Bold"/>

                        <Frame BackgroundColor="#F7F9FC"
                               BorderColor="#C9D6E8"
                               CornerRadius="12"
                               Padding="12">

                            <Entry Placeholder="Introduce tu contraseña"
                                   IsPassword="True"
                                   Text="{Binding Password}"
                                   TextColor="#1A1A1A"
                                   PlaceholderColor="#9AA4B1"
                                   BackgroundColor="Transparent"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Recordar contraseña -->
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <CheckBox IsChecked="{Binding RememberMe}" Color="#5A8CFF"/>
                        <Label Text="Recordar contraseña"
                               VerticalOptions="Center"
                               TextColor="#3A3A3A"
                               FontSize="15"/>
                    </HorizontalStackLayout>

                    <!-- Botón iniciar sesión -->
                    <Button Text="Iniciar sesión"
                            Command="{Binding LoginCommand}"
                            BackgroundColor="#5A8CFF"
                            TextColor="White"
                            CornerRadius="15"
                            HeightRequest="55"
                            FontSize="18"
                            FontAttributes="Bold"/>

                    <!-- Registrarse -->
                    <Label Text="¿No tienes cuenta? Regístrate"
                           HorizontalOptions="Center"
                           TextColor="#4A6CFF"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoRegisterCommand}" />
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- Recuperar contraseña -->
                    <Label Text="¿Has olvidado tu contraseña?"
                           HorizontalOptions="Center"
                           TextColor="#4A6CFF"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ForgotPasswordCommand}" />
                        </Label.GestureRecognizers>
                    </Label>

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
